flowchart TB
	%% Colorful deployment architecture matching actual project infra
	U["🌐 End Users"]
	DNS["🧭 Route 53 / Public DNS"]
	ALB["⚖️ Application Load Balancer\n(Head Entry Point)"]

	S3["🪣 Amazon S3\nFrontend Web Hosting"]

	subgraph VPC["☁️ AWS VPC (Same Network Boundary)"]
		direction TB
		SG["🛡️ Shared Security Group\n(ALB + Beanstalk + EC2 DB Rules)"]

		subgraph APP["Elastic Beanstalk Environment"]
			EB["🌱 Elastic Beanstalk\nNode.js / Express Backend API"]
		end

		subgraph DB["Database Tier on EC2"]
			EC2DB["🖥️ EC2 Instance\nPostgreSQL (Local DB Server)"]
		end
	end

	GH["🐙 GitHub Repository"]
	GHA["🔁 GitHub Actions CI/CD"]
	SM["🔐 AWS Secrets / Env Variables"]

	U --> DNS
	DNS --> ALB
	U --> S3

	ALB --> EB
	EB --> EC2DB

	SG -. applies policies .-> ALB
	SG -. applies policies .-> EB
	SG -. applies policies .-> EC2DB

	GH --> GHA
	GHA -->|Deploy frontend| S3
	GHA -->|Deploy backend| EB
	SM -. runtime injection .-> EB

